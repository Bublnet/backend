PORT=4000
PAYMENTS_SERVICE_URL=http://localhost:4001
# CORS origins for local testing + production.
# For Flutter web dev (default port 8080):
#   http://localhost:8080,http://127.0.0.1:8080
# Common others: http://localhost:5000 (sometimes used by Flutter), http://localhost:3000
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5000,http://localhost:3000,https://dvenueapp.vercel.app
# Required for secured server-side Firebase Admin access.
# For LOCAL development, you can paste the content of your downloaded service-account.json here.
 is promoted to admin when their profile is created.
DEFAULT_ADMIN_EMAIL=

# Dedicated admin-portal credentials. ADMIN_LOGIN_PASSWORD_HASH is preferred.
# Generate it with: npm run admin:hash-password -- "your strong password"
ADMIN_LOGIN_IDENTIFIER=
ADMIN_LOGIN_PASSWORD_HASH=
# Plaintext is supported for secret-manager environments but the hash takes precedence.
ADMIN_LOGIN_PASSWORD=
ADMIN_DISPLAY_NAME=Dvenue Administrator
ADMIN_SESSION_TTL_MINUTES=480

# Optional development-only signup OTP controls.
AUTH_DEV_OTP=
AUTH_RETURN_OTP=false
AUTH_RATE_LIMIT=30
WRITE_RATE_LIMIT=120

RAZORPAY_KEY_ID=

# Feature flags (set to false to disable)
# otpverify and googlesignin as requested
# For now: simulate OTP (direct password signup, no real OTP service calls for signup)
ENABLE_OTP_VERIFY=false
ENABLE_GOOGLE_SIGNIN=false

# Supabase (used by payments service for payments table and premium flags)
# Supabase Auth is the identity and role source of truth.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_server_secret_key

# Firebase service account credentials (for backend admin SDK - session tokens, Firestore reads/writes, user management)
# The service account details you provided (use the full JSON file for local dev):
# Email: firebase-adminsdk-r6egv@inventory-management-ce97e.iam.gserviceaccount.com
# Key ID: 3376080a19fa54c9815c266c059a842c845b7a57
# OAuth 2 client ID: 113494383703598092954
#
# For local development, place the full service-account.json in backend/ and point to it (already wired in run-backend.ps1 and code).
# For production (Vercel etc.): set FIREBASE_SERVICE_ACCOUNT_BASE64 to the base64 of the full JSON.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
