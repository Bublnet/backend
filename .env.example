PORT=4000
PAYMENTS_SERVICE_URL=http://localhost:4001
CORS_ORIGINS=http://localhost:3000,http://localhost:4000,https://dvenueapp.vercel.app

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Required for secured server-side Firebase Admin access.
# Prefer BASE64 in hosted env vars because it avoids JSON escaping issues.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=

# First matching email is promoted to admin when their profile is created.
DEFAULT_ADMIN_EMAIL=

# Optional development-only signup OTP controls.
AUTH_DEV_OTP=
AUTH_RETURN_OTP=false
AUTH_RATE_LIMIT=30
WRITE_RATE_LIMIT=120

RAZORPAY_KEY_ID=
